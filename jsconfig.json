{
  "compilerOptions": {
    "checkJs": true,
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": false,
    "noEmit": true
  },
  "include": [
    "background/**/*.js",
    "shared/**/*.js",
    "popup/*.js",
    "platforms/**/*.js"
  ],
  "exclude": [
    "lib",
    "platforms/facebook/content.js",
    "platforms/instagram/content.js"
  ]
}
